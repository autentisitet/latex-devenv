# Automatic text processing, binary files remain unchanged.
* text=auto


# Force shell scripts to use LF
**/*.sh text eol=lf

# Force PowerShell scripts to use CRLF
**/*.ps1 text eol=crlf
**/*.psm1    text eol=crlf


# Documents and configuration files: Force the use of LF storage and enable LaTeX-specific Diff.
**/*.md      text eol=lf
**/*.tex     text eol=lf diff=tex
**/*.cls     text eol=lf diff=tex
**/*.sty     text eol=lf diff=tex
**/*.bib     text eol=lf
.gitignore   text eol=lf
LICENSE      text eol=lf


# Binary files: Strictly prohibit any newline character conversion.
*.pdf        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.ttf        binary
*.otf        binary
*.woff       binary
*.woff2      binary


# Eliminate interference from non-source code files.
*.log        -text
*.aux        -text